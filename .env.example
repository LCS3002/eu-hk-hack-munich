# ─── Harbour environment ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values you need.
# The demo degrades gracefully when values are missing — the AI gate streams
# a deterministic fixture verdict and the chain falls back to a mock tx.

# ── AI gate ──────────────────────────────────────────────────────────────────
# Anthropic API key — OPTIONAL.
# api/verify checks HARBOUR_ANTHROPIC_KEY first, then ANTHROPIC_API_KEY.
# Without a key, the fixture reasoning is replayed at typewriter speed.
HARBOUR_ANTHROPIC_KEY=
ANTHROPIC_API_KEY=

# ── Chain mode ────────────────────────────────────────────────────────────────
# "local"   → Hardhat node at RPC_URL (default http://127.0.0.1:8545)
# "sepolia" → Ethereum Sepolia testnet (needs RPC_URL + ORACLE_PRIVATE_KEY)
# "mock"    → no RPC; returns a synthetic tx hash (safe demo fallback)
NEXT_PUBLIC_CHAIN_MODE=mock

# ── Local Hardhat node (NEXT_PUBLIC_CHAIN_MODE=local) ─────────────────────────
# 1. Start the node:      npm run chain:node
# 2. Deploy contracts:    npm run chain:deploy:local
# 3. Copy the printed addresses below, set ORACLE_PRIVATE_KEY to Hardhat
#    account #0's key (0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80)
RPC_URL=http://127.0.0.1:8545
ORACLE_PRIVATE_KEY=

# Printed by npm run chain:deploy:local (also written to contracts/deployment.json):
ESCROW_ADDRESS=
USDC_ADDRESS=

# ── Sepolia testnet (NEXT_PUBLIC_CHAIN_MODE=sepolia) ──────────────────────────
# RPC_URL=https://ethereum-sepolia-rpc.publicnode.com   # or your Alchemy/Infura URL
# ORACLE_PRIVATE_KEY=<your-sepolia-wallet-private-key>
# ESCROW_ADDRESS=0x9527bAc8dDf0A3d3B42Af0F0C11F48fe1253540E  # already deployed
# USDC_ADDRESS=0x4dA689E28D7C99C624a7e4280C06e1fF59937be2    # already deployed
# SEPOLIA_RPC_URL=  # used only by Hardhat when running deploy:sepolia
# SEPOLIA_PRIVATE_KEY=

# ── Client-side Etherscan context (NEXT_PUBLIC_*) ─────────────────────────────
# These power the clickable wallet/contract links in the settlement console.
# Buyer = the oracle wallet that funds escrow; supplier = the CLEAR recipient.
NEXT_PUBLIC_EXPLORER_BASE=https://sepolia.etherscan.io
NEXT_PUBLIC_BUYER_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_SUPPLIER_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

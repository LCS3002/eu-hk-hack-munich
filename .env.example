# ─── Harbour environment ───────────────────────────────────────────────
# Anthropic API key — OPTIONAL. Without it, the proof-of-trade gate streams a
# deterministic fixture verdict so the demo still runs end-to-end.
ANTHROPIC_API_KEY=

# EVM testnet (Sepolia) — needed ONLY for the real Etherscan link.
# A local Hardhat node needs none of these (deploy script prints local addresses).
RPC_URL=
ORACLE_PRIVATE_KEY=

# Filled in after deployment (deploy script prints these):
ESCROW_ADDRESS=
USDC_ADDRESS=

# Set to "local" for the in-memory Hardhat node, "sepolia" for testnet,
# or "mock" to bypass the chain entirely (demo fallback if RPC dies).
NEXT_PUBLIC_CHAIN_MODE=local
